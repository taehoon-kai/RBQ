<?xml version="1.0" encoding="utf-8"?>
<mujoco model="rbq10">
    <!-- 컴파일러 설정 -->
    <compiler 
        angle="radian" 
        coordinate="local" 
        meshdir="../meshes/"
        texturedir="../meshes/"
        autolimits="true"
    />

    <!-- 옵션 설정 -->
    <option 
        timestep="0.001" 
        gravity="0 0 -9.81"
        integrator="RK4"
        cone="elliptic"
        impratio="100"
        tolerance="1e-10"
    >
        <flag warmstart="enable" energy="enable" contact="enable" frictionloss="enable"/>
    </option>

    <!-- 기본 클래스 정의 -->
    <default>
        <default class="rbq10">
            <geom friction="0.4" margin="0.001" condim="1"/>
            
            <default class="abduction">
                <joint axis="1 0 0" range="-0.5411 0.7330" damping="0.1" armature="0.014058265" frictionloss="1.2"/>
                <motor ctrlrange="-100 100"/>
            </default>
            <default class="hip">
                <default class="front_hip">
                    <joint axis="0 1 0" range="-6.2832 6.2832" damping="0.1" armature="0.014058265" frictionloss="1.2"/>
                    <motor ctrlrange="-100. 100"/>
                </default>
                <default class="back_hip">
                    <joint axis="0 1 0" range="-6.2832 6.2832" damping="0.1" armature="0.014058265" frictionloss="1.2"/>
                    <motor ctrlrange="-100. 100"/>
                </default>
            </default> 
            <default class="knee">
                <joint axis="0 1 0" range="-2.8274 -0.4189" damping="0.1" armature="0.0214816" frictionloss="1.2"/>
                <motor ctrlrange="-150. 150"/>
            </default>
            <default class="visual">
                <geom type="mesh" contype="0" conaffinity="0" group="2"/>
            </default>
            <default class="collision">
                <geom contype="1" conaffinity="1" group="3"/>
                <default class="foot">
                    <geom type="sphere" size="0.03" priority="1" condim="6"
                        friction="0.4 0.02 0.01" solref="0.02 1" solimp="0.9 0.95 0.001"/>
                 </default>
            </default>
        </default>
    </default>
    
    <equality> <!--define rolling contact joint-->
    <joint joint2="LIMS_EX_Elbow_Joint_2" joint1="LIMS_EX_Elbow_Joint_1" polycoef="0 1 0 0 0" active="true"/>
    <joint joint2="LIMS_EX_Gripper_Joint_2" joint1="LIMS_EX_Gripper_Joint_1" polycoef="0 1 0 0 0" active="true"/>
    </equality>

    <!-- 에셋 정의 -->
    <asset>
        <!-- 재질 정의 -->
        <material name="metal" rgba=".9 .95 .95 1"/>
        <material name="black" rgba="0 0 0 1"/>
        <material name="white" rgba="1 1 1 1"/>
        <material name="gray" rgba="0.671705 0.692426 0.774270 1"/>
        <material name="tan" rgba="0.823 0.706 0.549 1"/>
        <material name="palegoldenrod" rgba="0.9334 0.91 0.667 1.0"/>
        <material name="charcoal" rgba="0.3 0.3 0.3 1.0"/>
        <material name="darker_gray" rgba="0.2 0.2 0.2 1.0"/>
        <material name="trunk_material" texture="trunk_texture"/>

        <texture name="trunk_texture" type="2d" file="trunk.png" />

        <mesh name="trunk" file="base/simple_trunk.obj" scale="1 1 1"/>
        <mesh name="FRR_link" file="base/FRR_link.obj" scale="1 1 1"/>
        <mesh name="FLR_link" file="base/FLR_link.obj" scale="1 1 1"/>
