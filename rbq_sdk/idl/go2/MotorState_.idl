module unitree_go {
  module msg {
    module dds_ {
      @extensibility(FINAL)
      struct MotorState_ {
        uint8 mode;
        float q;
        float dq;
        float ddq;
        float tau_est;
        float q_raw;
        float dq_raw;
        float ddq_raw;
        uint8 temperature;
        uint32 lost;
        uint32 reserve[2];
      };
    };
  };
};
