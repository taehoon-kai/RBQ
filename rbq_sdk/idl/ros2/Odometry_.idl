#include "PoseWithCovariance_.idl"
#include "TwistWithCovariance_.idl"
#include "Header_.idl"

module nav_msgs {
  module msg {
    module dds_ {
      @extensibility(FINAL)
      struct Odometry_ {
        std_msgs::msg::dds_::Header_ header;
        string child_frame_id;
        geometry_msgs::msg::dds_::PoseWithCovariance_ pose;
        geometry_msgs::msg::dds_::TwistWithCovariance_ twist;
      };
    };
  };
};
